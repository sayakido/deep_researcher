# 搜索引擎配置
# 可选：duckduckgo（免 API Key）、tavily（需 TAVILY_API_KEY）、perplexity（需 PERPLEXITY_API_KEY）、searxng（自建实例）
SEARCH_API=tavily
TAVILY_API_KEY=tvly-your-api-key-placeholder

# LLM 配置 — DeepSeek（OpenAI 兼容）
LLM_PROVIDER=custom
LLM_MODEL_ID=deepseek-chat
LLM_API_KEY=sk-your-api-key-placeholder
LLM_BASE_URL=https://api.deepseek.com

# 本地模型（取消注释覆盖上方配置）
# LLM_PROVIDER=ollama
# LOCAL_LLM=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# LLM_PROVIDER=lmstudio
# LOCAL_LLM=qwen_qwq-32b
# LMSTUDIO_BASE_URL=http://localhost:1234/v1

# 服务器
HOST=0.0.0.0
PORT=8000

# CORS
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,http://localhost:5173,http://localhost:3000

# 日志
LOG_LEVEL=INFO
LOG_FILE=runtime/logs/app.log
LOG_ROTATION=20 MB
LOG_RETENTION=7 days

FETCH_FULL_PAGE=True

# 笔记（可选）
# ENABLE_NOTES=false
NOTES_WORKSPACE=runtime/notes/dev
